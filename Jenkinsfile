pipeline {
    agent any

    stages {
        stage('Clone') {
            steps {
                echo 'Cloning done automatically by Jenkins'
            }
        }

        stage('Build') {
            steps {
                echo 'Building Parking Management System 🚗'
            }
        }

        stage('Test') {
            steps {
                echo 'Testing project...'
            }
        }

        stage('Deploy') {
            steps {
                echo 'Deploying project...'
            }
        }
    }
}
